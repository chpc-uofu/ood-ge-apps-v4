#!/usr/bin/env bash
# Export the module function if it exists
[[ $(type -t module) == "function" ]] && export -f module

CRYOSPARC_SUBDOMAIN_JOB_NAME="ondemand/sys/dashboard/<%= File.basename(File.dirname(File.dirname(File.dirname(session.staged_root.to_s)))) %>/<%= File.basename(File.dirname(File.dirname(session.staged_root.to_s))) %>"

existing_cryosparc_job_id=$(
  squeue -M All -h -u "${USER}" -t RUNNING,PENDING -o "%i|%j" 2>/dev/null | \
    awk -F'|' -v job_name="${CRYOSPARC_SUBDOMAIN_JOB_NAME}" -v current_job_id="${SLURM_JOB_ID:-}" '
      $2 == job_name && $1 != current_job_id { print $1; exit }
    '
)

if [[ -n "${existing_cryosparc_job_id}" ]]; then
  echo "You already have a running or queued CryoSPARC subdomain session. Stop that session before starting another."
  exit 1
fi

export OOD_SESSION_ID="<%= File.basename(session.staged_root.to_s) %>"
echo "$OOD_SESSION_ID"

export SELECTED_CRYO_VERSION="<%= context.version %>"
echo "Selected version: $SELECTED_CRYO_VERSION"

# port=$(find_port ${host} 2000 30000)
# echo "nginx port=$port"

# Find available port to run cryosparc server on
export port=$(find_port ${host} 30001 65535)
echo "cryosparc port=$port"
CRYOSPARC_PORT=$port
export CRYOSPARC_PORT


# -----------------------------
# CONFIG (adjust these)
# -----------------------------
FRPS_ADDR="155.101.26.122"
FRPS_PORT="7000"

BASE_DOMAIN="cryosparc.ondemand-staging.chpc.utah.edu"   # or cryosparc.example.edu
VHOST_PORT="7001"
USER_ACCESS_PORT="8443"


CRYOSPARC_PORT="${port}"
CLUSTER_NAME="${SLURM_CLUSTER_NAME:-cluster}"

# -----------------------------
# JOB CONTEXT
# -----------------------------
JOB_ID="${SLURM_JOB_ID:-jobid}"
USER_NAME="${USER:-user}"

# sanitize (DNS-safe)
sanitize() {
  echo "$1" | tr '[:upper:]' '[:lower:]' | tr -cd 'a-z0-9-'
}

USER_NAME=$(sanitize "$USER_NAME")
CLUSTER_NAME=$(sanitize "$CLUSTER_NAME")
export OOD_SESSION_ID_SHORT="${OOD_SESSION_ID:0:4}"
# -----------------------------
# RANDOM SUFFIX
# -----------------------------
RAND_SUFFIX=$(tr -dc a-z0-9 </dev/urandom | head -c 4)

export SUBDOMAIN="${USER_NAME}-o${OOD_SESSION_ID_SHORT}-${CLUSTER_NAME}-j${JOB_ID}-p${CRYOSPARC_PORT}-${RAND_SUFFIX}"
#EXTERNAL_URL="https://${SUBDOMAIN}.${BASE_DOMAIN}:${VHOST_PORT}/login"

EXTERNAL_URL="https://${SUBDOMAIN}.${BASE_DOMAIN}:${USER_ACCESS_PORT}/login"

export SUBDOMAIN
export EXTERNAL_URL

export external_url=$EXTERNAL_URL

echo "Subdomain: $SUBDOMAIN"
echo "URL: $EXTERNAL_URL"

# -----------------------------
# GENERATE FRPC CONFIG
# -----------------------------
export TOKEN_FILE="${PWD}/.frp_token"
cat > "${PWD}/frpc.toml" <<EOF
serverAddr = "${FRPS_ADDR}"
serverPort = ${FRPS_PORT}

auth.tokenSource.type = "file"
auth.tokenSource.file.path = "${TOKEN_FILE}"
loginFailExit = false

transport.dialServerTimeout = 30
transport.heartbeatInterval = 30
transport.heartbeatTimeout = 120

[[proxies]]
name = "cryosparc-${USER_NAME}-${JOB_ID}"
type = "http"
localIP = "127.0.0.1"
localPort = ${CRYOSPARC_PORT}
subdomain = "${SUBDOMAIN}"
EOF

chmod 600 "${PWD}/frpc.toml"

## render stage
<%
require "fileutils"
render_logs = File.join(session.staged_root, ".render_logs")
unless File.exist?(render_logs)
  user = `whoami`.strip
  File.open(render_logs, "a") do |f|
    f.puts "user=#{user}"
  end
end
%>
<%
require "fileutils"
token_path = File.join(session.staged_root, ".frp_token")
unless File.exist?(token_path)
  src = "/uufs/chpc.utah.edu/common/home/u6047586/ondemand/ood-ge-apps-v4/cryosparc_app_subdomain/frp/.frp_token"
  FileUtils.cp(src, token_path)
  FileUtils.chmod(0600, token_path)
end
%>
