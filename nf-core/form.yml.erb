  nf_params:
    widget: "path_selector"
    label: "Parameter YAML File"
    show_files: true
    help: "Parameters are unique to each pipeline, detailed at https://nf-co.re/pipelines. Upload a YAML file with your necessary parameters."

  cluster:
    widget: select
    options:
      <%- CustomQueues.clusters.each do |g| %>
      - "<%= g %>"
      <%- end %>
<% IO.foreach(template_root+"friscos_v2") do |line| %>
<%= line %>
<% end %>    
<% IO.foreach(template_root+"cluster-help") do |line| %>
<%= line %>
<% end %>    
  custom_accpart:
    widget: select
    options:
      <%- CustomAccPart.accpart.each do |g| %>
      - "<%= g %>"
      <%- end %>
<% IO.foreach(template_root+"accpart-help") do |line| %>
<%= line %>
<% end %>    

<% IO.foreach(template_root+"job_params_v33") do |line| %>
<%= line %>
<% end %>   

  gpudata:
    widget: "hidden_field"
    cacheable: false
    value: |
      "<%= gpu_data.to_json %>"
   
  bc_num_hours:
    value: 1
    min: 1
    max: 72
    step: 1
  bc_email_on_started:
    help: "If you do not receive the email, check your [Profile](https://www.chpc.utah.edu/role/user/edit_profile.php) for correct address."
  workdir:
    label: "Working Directory"
    widget: "path_selector"
    directory: "/scratch/general/vast"
    required: false
    help: "This is the location where your job will run. Using the scratch space is highly recommended."
  outdir:
    label: "Output Directory"
    widget: "path_selector"
    required: false
    help: "This is where output files will be stored."
  resume:
    label: "Resume"
    widget: "check_box"
    checked_value: 1
    unchecked_value: 0
    help: "Resume previous run if found."

  tower_access_token:
    widget: "text_field"
    required: false
    label: "TOWER_ACCESS_TOKEN (Optional)"
    help: "Your Seqera TOWER_ACCESS_TOKEN used to monitor runs on [Nextflow Tower](https://seqera.io)."

form:
  - pipeline
  - nf_params
  - workdir
  - outdir
<% IO.foreach(template_root+"form_params_gpu") do |line| %>
<%= line %>
<% end %>
  - tower_access_token
  - resume