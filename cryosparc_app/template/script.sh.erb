#!/usr/bin/env bash


set -x
module purge
module load apptainer

export APPTAINERENV_USER_CRYOSPARC_DIRECTORY="/scratch/general/vast/$USER/ood_cryosparc_app/.cryosparc-v4.7.1"
export APPTAINERENV_NGINX_PORT=${port}
export APPTAINERENV_CRYOSPARC_BASE_PORT=${port2}
##export APPTAINERENV_CRYOSPARC_BASE_PORT=39000
export APPTAINERENV_CRYOSPARC_LICENSE_ID=cd5d7832-ae84-11f0-b06a-df8cfaccd61d

##simage_path1="/uufs/chpc.utah.edu/common/home/u6047586/dor-hprc-ood-apps/cryosparc/INSTALL/cryosparc-v4.7.1-cuda12+250814.sif"
##simage_path2="/uufs/chpc.utah.edu/common/home/u6047586/dor-hprc-ood-apps/cryosparc/template/cryosparc-v4.7.1-cuda12+250814"

simage_path="/uufs/chpc.utah.edu/common/home/u6047586/dor-hprc-ood-apps/cryosparc/INSTALL/cryosparc-v4.7.1-cuda12+250814-nginx.sif"

user_cryosparc_directory=$APPTAINERENV_USER_CRYOSPARC_DIRECTORY

if [ ! -d "$user_cryosparc_directory" ]; then
    echo "first launch"
    export APPTAINERENV_FIRST_LAUNCH=true
    mkdir -p "$user_cryosparc_directory"
    mkdir "$user_cryosparc_directory/cryosparc_license"
    mkdir "$user_cryosparc_directory/cryosparc_cache"
    mkdir "$user_cryosparc_directory/cryosparc_database"

    tar xzf /uufs/chpc.utah.edu/common/home/u6047586/dor-hprc-ood-apps/cryosparc/bk_cryosparc_master_run_init_files-v4.7.1.tar.gz -C $user_cryosparc_directory
else
    echo "NOT first launch"
    export APPTAINERENV_FIRST_LAUNCH=false
fi

##nginx
mkdir -p ./nginx/var/log/nginx
mkdir -p ./nginx/var/lib/nginx
mkdir -p ./nginx/etc/nginx/sites-enabled

##sed "s/_FORWARD_PORT_/${port}/g" /uufs/chpc.utah.edu/common/home/u6047586/dor-hprc-ood-apps/cryosparc/template/cryosparc.nginx_template2 > ./cryosparc.nginx
sed "s/_FORWARD_PORT_/${port}/g" /uufs/chpc.utah.edu/common/home/u6047586/dor-hprc-ood-apps/cryosparc/template/cryosparc.nginx_template > ./cryosparc.nginx
sed -i "s/_FORWARD_HOST_/${host}/g" ./cryosparc.nginx
sed -i "s/_APP_PORT_/${port2}/g" ./cryosparc.nginx

cp ./cryosparc.nginx ./nginx/etc/nginx/sites-enabled/

cryo_instance=ood_cryosparc_${USER}_${SLURM_JOB_ID}_n${port}_c${port2}
echo $cryo_instance

apptainer instance start --writable-tmpfs --nv \
-B ./nginx/etc/nginx/sites-enabled:/etc/nginx/sites-enabled \
-B ./nginx/var/log/nginx:/var/log/nginx \
-B ./nginx/var/lib/nginx:/var/lib/nginx \
-B $user_cryosparc_directory/cryosparc_master/run:/cryosparc_master/run \
-B $TMPDIR:/tmp -B /uufs -B /scratch \
-B $user_cryosparc_directory/cryosparc_database:/cryosparc_database \
-B $user_cryosparc_directory/cryosparc_cache:/cryosparc_cache \
-B $user_cryosparc_directory/cryosparc_license:/cryosparc_license \
-B /uufs/chpc.utah.edu/common/home/u6047586/dor-hprc-ood-apps/cryosparc/supervisord.conf:/cryosparc_master/supervisord.conf \
$simage_path \
$cryo_instance

##the last step of this script is a blocking process (nginx)
apptainer exec instance://$cryo_instance /uufs/chpc.utah.edu/common/home/u6047586/dor-hprc-ood-apps/cryosparc/template/script4.sh


